<article class="post-card" data-post-id="<%= post.id %>">
  <!-- Post Header -->
  <div class="post-header">
    <a href="/profile/<%= post.username %>" class="post-user-info">
      <img src="<%= post.avatar %>" alt="<%= post.username %> avatar" class="avatar avatar-md" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
      <span class="post-username"><%= post.username %></span>
    </a>
    <button class="btn-icon post-more-btn" aria-label="More options">
      <svg fill="currentColor" height="24" viewBox="0 0 24 24" width="24">
        <circle cx="12" cy="12" r="1.5"/><circle cx="6" cy="12" r="1.5"/><circle cx="18" cy="12" r="1.5"/>
      </svg>
    </button>
  </div>
  
  <!-- Post Image Container (Double-tap to like) -->
  <div class="post-image-container">
    <img src="<%= post.image_path %>" alt="Photo by <%= post.username %>" class="post-image" loading="lazy">
    <!-- Floating heart on double tap -->
    <div class="floating-heart">
      <svg fill="#FFFFFF" height="80" viewBox="0 0 24 24" width="80">
        <path d="M16.792 3.904A4.989 4.989 0 0 1 21.5 9.122c0 3.072-2.652 4.959-5.197 7.222-2.512 2.243-3.865 3.469-4.303 3.752-.477-.309-1.834-1.587-4.303-3.752C5.141 14.072 2.5 12.167 2.5 9.122a4.989 4.989 0 0 1 4.708-5.218 4.21 4.21 0 0 1 3.675 1.941c.84 1.175.98 1.763 1.12 1.763s.278-.588 1.11-1.766a4.17 4.17 0 0 1 3.679-1.938"/>
      </svg>
    </div>
  </div>
  
  <!-- Action Buttons -->
  <div class="post-actions">
    <div class="post-actions-left">
      <!-- Like button -->
      <button class="btn-icon like-btn <%= post.is_liked ? 'liked' : '' %>" data-post-id="<%= post.id %>" aria-label="<%= post.is_liked ? 'Unlike' : 'Like' %>">
        <% if (post.is_liked) { %>
          <svg fill="#ED4956" height="24" viewBox="0 0 24 24" width="24">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        <% } else { %>
          <svg fill="currentColor" height="24" viewBox="0 0 24 24" width="24">
            <path d="M16.792 3.904A4.989 4.989 0 0 1 21.5 9.122c0 3.072-2.652 4.959-5.197 7.222-2.512 2.243-3.865 3.469-4.303 3.752-.477-.309-1.834-1.587-4.303-3.752C5.141 14.072 2.5 12.167 2.5 9.122a4.989 4.989 0 0 1 4.708-5.218 4.21 4.21 0 0 1 3.675 1.941c.84 1.175.98 1.763 1.12 1.763s.278-.588 1.11-1.766a4.17 4.17 0 0 1 3.679-1.938m0-2a6.04 6.04 0 0 0-4.797 2.127 6.052 6.052 0 0 0-4.787-2.127A6.985 6.985 0 0 0 .5 9.122c0 3.61 2.55 5.827 5.015 7.97.283.246.569.494.853.747l1.027.918a44.998 44.998 0 0 0 3.518 3.018 2 2 0 0 0 2.174 0 45.263 45.263 0 0 0 3.626-3.115l.922-.824c.293-.26.59-.519.885-.774 2.334-2.025 4.98-4.32 4.98-7.94a6.985 6.985 0 0 0-6.708-7.218Z"/>
          </svg>
        <% } %>
      </button>
      
      <!-- Comment button -->
      <button class="btn-icon comment-btn" aria-label="Comment">
        <svg fill="currentColor" height="24" viewBox="0 0 24 24" width="24">
          <path d="M20.656 17.008a9.993 9.993 0 1 0-3.59 3.615L22 22Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
      
      <!-- Share button -->
      <button class="btn-icon share-btn" aria-label="Share">
        <svg fill="currentColor" height="24" viewBox="0 0 24 24" width="24">
          <line fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2" x1="22" x2="9.218" y1="3" y2="10.083"/>
          <polygon fill="none" points="11.698 20.334 22 3.001 2 3.001 9.218 10.084 11.698 20.334" stroke="currentColor" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
    </div>
    
    <!-- Bookmark button -->
    <button class="btn-icon save-btn" aria-label="Save">
      <svg fill="currentColor" height="24" viewBox="0 0 24 24" width="24">
        <polygon fill="none" points="20 21 12 13.44 4 21 4 3 20 3 20 21" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
      </svg>
    </button>
  </div>
  
  <!-- Post Metadata / Likes / Caption / Comments -->
  <div class="post-info">
    <div class="post-likes"><span class="likes-count"><%= post.likes_count %></span> likes</div>
    
    <!-- Caption -->
    <% if (post.caption && post.caption.trim() !== '') { %>
      <div class="post-caption">
        <a href="/profile/<%= post.username %>" class="caption-username"><%= post.username %></a>
        <span class="caption-text"><%= post.caption %></span>
      </div>
    <% } %>
    
    <!-- View Comments Link -->
    <% if (post.comments_count > 5) { %>
      <button class="view-comments-link text-left pointer" style="background:none;border:none;padding:0;text-align:left;">
        View all <%= post.comments_count %> comments
      </button>
    <% } %>
    
    <!-- Comments List Container -->
    <div class="comments-list">
      <% if (post.comments && post.comments.length > 0) { %>
        <% post.comments.forEach(comment => { %>
          <div class="post-comment">
            <a href="/profile/<%= comment.username %>" class="comment-username"><%= comment.username %></a>
            <span><%= comment.content %></span>
          </div>
        <% }) %>
      <% } %>
    </div>
    
    <!-- Timestamp -->
    <time class="post-time" datetime="<%= post.created_at %>"><%= formatTimeAgo(post.created_at) %></time>
    
    <!-- Add Comment Inline Form -->
    <form class="add-comment-form" data-post-id="<%= post.id %>">
      <input type="text" placeholder="Add a comment..." class="comment-input" name="content" autocomplete="off">
      <button type="submit" class="comment-post-btn" disabled>Post</button>
    </form>
  </div>
</article>
